@model List<Ipms.Frontend.Models.InsuranceSchemeViewModel>
@{
    ViewData["Title"] = "Insurance Schemes";
}
<link rel="stylesheet" href="~/css/schemelist.css" />


<div class="schemes-wrapper">

    <div class="page-header">
        <div>
            <h6>Admin Panel</h6>
            <h2><i class="bi bi-shield-check me-2"></i>Insurance Schemes</h2>
        </div>
        <a asp-controller="Scheme" asp-action="CreateInsuranceScheme" class="btn-create">
            <i class="bi bi-plus-circle"></i> Create New Scheme
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3 mb-3">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3 mb-3">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="schemes-grid">
            @foreach (var scheme in Model)
            {
                <div class="scheme-card @(!scheme.IsActive ? "inactive" : "")">
                    <div class="card-top">
                        <div class="scheme-header">
                            <div>
                                <div class="scheme-name">@scheme.SchemeName</div>
                            </div>
                            @if (scheme.IsActive)
                            {
                                <span class="badge-active">
                                    <span class="status-dot"></span> Active
                                </span>
                            }
                            else
                            {
                                <span class="badge-inactive">
                                    <span class="status-dot"></span> Inactive
                                </span>
                            }
                        </div>

                        <div class="scheme-desc">@scheme.Description</div>

                        <div class="info-chips">
                            <div class="chip">
                                <i class="bi bi-person-badge"></i>
                                Age: <strong>@scheme.MinAge – @scheme.MaxAge yrs</strong>
                            </div>
                            <div class="chip">
                                <i class="bi bi-currency-rupee"></i>
                                <strong>₹@scheme.MinAmount.ToString("N0") – ₹@scheme.MaxAmount.ToString("N0")</strong>
                            </div>
                            <div class="chip">
                                <i class="bi bi-graph-up-arrow"></i>
                                Profit: <strong>@scheme.ProfitRatio%</strong>
                            </div>
                        </div>
                    </div>

                    <div class="card-actions">
                        <a asp-controller="Scheme" asp-action="EditScheme"
                           asp-route-id="@scheme.SchemeId" class="btn-edit">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form asp-controller="Scheme" asp-action="ToggleActive" method="post" class="d-contents" style="flex:1; display:contents">
                            <input type="hidden" name="id" value="@scheme.SchemeId" />
                            @if (scheme.IsActive)
                            {
                                <input type="hidden" name="isActive" value="false" />
                                <button type="submit" class="btn-toggle-deactivate">
                                    <i class="bi bi-toggle-on"></i> Deactivate
                                </button>
                            }
                            else
                            {
                                <input type="hidden" name="isActive" value="true" />
                                <button type="submit" class="btn-toggle-activate">
                                    <i class="bi bi-toggle-off"></i> Activate
                                </button>
                            }
                        </form>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-shield-exclamation"></i>
            <h5>No Schemes Found</h5>
            <p>Create your first insurance scheme to get started.</p>
            <a asp-controller="Scheme" asp-action="CreateInsuranceScheme" class="btn-create" style="display:inline-flex; margin-top:1rem">
                <i class="bi bi-plus-circle"></i> Create Scheme
            </a>
        </div>
    }

</div>
