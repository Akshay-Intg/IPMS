@model Ipms.Frontend.Models.CustomerListViewModel
@{
    ViewData["Title"] = "Customer List";
}
<link rel="stylesheet" href="~/css/getall.css" />
<div class="customer-list-wrapper">

    <div class="page-header">
        <h2><i class="bi bi-people-fill me-2"></i>Customer List</h2>
        <span class="record-count">
            @Model.TotalRecords customer@(Model.TotalRecords != 1 ? "s" : "") total
        </span>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3">@TempData["Error"]</div>
    }

    <form asp-controller="Admin" asp-action="GetAll" method="get" class="search-bar">
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
        <div class="search-input-wrap">
            <i class="bi bi-search search-icon"></i>
            <input type="text" name="search" maxlength="15" value="@Model.Search"
                   placeholder="Search customers..." />
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a asp-controller="Admin" asp-action="GetAll"
                   asp-route-pageSize="@Model.PageSize" class="clear-btn">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
            <button type="submit" class="btn-search">
                <i class="bi bi-search"></i> Search
            </button>
        </div>
    </form>

    <div class="table-card">
        <div class="table-responsive" style="max-height: 60vh; overflow-y: auto;">
            <table class="table table-hover mb-0" style="min-width: 1100px;">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Gender</th>
                    <th>Date of Birth</th>
                    <th>Address</th>
                    <th>City</th>
                    <th>State</th>
                    <th>ZipCode</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Customers != null && Model.Customers.Any())
                {
                    foreach (var customer in Model.Customers)
                    {
                        <tr>
                            <td>@customer.firstName @customer.lastName</td>
                            <td>@customer.email</td>
                            <td>@customer.phoneNo</td>
                            <td>@customer.gender</td>
                            <td>@customer.dateOfBirth.ToString("dd MMM yyyy")</td>
                            <td>@customer.addressLine1</td>
                            <td>@customer.city</td>
                            <td>@customer.state</td>
                            <td>@customer.zipCode</td>
                                <td style="white-space: nowrap; vertical-align: middle;">
                                    @if (customer.IsDeleted)
                                    {
                                        <span class="badge" style="background:#fdd9d9; color:#b00020;">
                                            🗑 Deleted
                                        </span>
                                    }
                                    else if (customer.isActive == true)
                                    {
                                        <span class="badge-active">● Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge" style="background:#fdecd4; color:#b05a00;">
                                            ● Inactive
                                        </span>
                                    }
                                </td>
                            <td>
                                <a asp-controller="Admin" asp-action="EditCustomer"
                                   asp-route-id="@customer.customerID"
                                   class="btn-edit">Edit</a>
                            </td>
                        </tr>

                    }
                }
                else
                {
                    <tr>
                        <td colspan="12" class="no-results">
                            <i class="bi bi-people"></i>
                            @if (!string.IsNullOrEmpty(Model.Search))
                            {
                                <span>No customers found for "<strong>@Model.Search</strong>"</span>
                            }
                            else
                            {
                                <span>No customers found.</span>
                            }
                        </td>
                    </tr>

                }
            </tbody>
        </table>
    </div>
    </div>

    @if (Model.TotalPages >= 1)
    {
        <div class="pagination-wrapper">
            <div class="pagesize-selector">
                <span>Rows per page:</span>
                @foreach (var size in new[] { 5, 10, 25, 50 })
                {
                    <a asp-controller="Admin" asp-action="GetAll"
                       asp-route-page="1"
                       asp-route-search="@Model.Search"
                       asp-route-pageSize="@size"
                       class="@(Model.PageSize == size ? "active-size" : "")">@size</a>
                }
            </div>

            <div class="d-flex align-items-center gap-3">
                <span class="text-muted" style="font-size:0.83rem;">
                    Showing @((Model.CurrentPage - 1) * Model.PageSize + 1)–@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalRecords)) of @Model.TotalRecords
                </span>
                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link"
                               asp-controller="Admin" asp-action="GetAll"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-search="@Model.Search"
                               asp-route-pageSize="@Model.PageSize">‹ Prev</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-controller="Admin" asp-action="GetAll"
                                   asp-route-page="@i"
                                   asp-route-search="@Model.Search"
                                   asp-route-pageSize="@Model.PageSize">@i</a>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <a class="page-link"
                               asp-controller="Admin" asp-action="GetAll"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-search="@Model.Search"
                               asp-route-pageSize="@Model.PageSize">Next ›</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }

</div>
