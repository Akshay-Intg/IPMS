@model List<Ipms.Frontend.Models.BrokerViewModel>
@{
    ViewData["Title"] = "Manage Brokers";
}
<link rel="stylesheet" href="~/css/Brokers.css" />


<div class="broker-wrapper">

    <!-- Header -->
    <div class="broker-page-header">
        <div>
            <h6>Admin Panel</h6>
            <h2><i class="bi bi-person-badge me-2"></i>Broker Management</h2>
            <div class="type-badge">
                <i class="bi bi-people-fill"></i> @Model.Count broker@(Model.Count != 1 ? "s" : "") registered
            </div>
        </div>
        <button class="btn-add" data-bs-toggle="modal" data-bs-target="#addBrokerModal">
            <i class="bi bi-plus-circle"></i> Add New Broker
        </button>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3 mb-3">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3 mb-3">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
        </div>
    }

    <!-- Stats Row -->
    <div class="stats-row">
        <div class="stat-card">
            <i class="bi bi-people-fill"></i>
            <div>
                <div class="stat-num">@Model.Count</div>
                <div class="stat-label">Total Brokers</div>
            </div>
        </div>
        <div class="stat-card">
            <i class="bi bi-check-circle-fill" style="color:#27ae60;"></i>
            <div>
                <div class="stat-num">@Model.Count(b => b.IsActive)</div>
                <div class="stat-label">Active Brokers</div>
            </div>
        </div>
        <div class="stat-card">
            <i class="bi bi-x-circle-fill" style="color:#e74c3c;"></i>
            <div>
                <div class="stat-num">@Model.Count(b => !b.IsActive)</div>
                <div class="stat-label">Inactive Brokers</div>
            </div>
        </div>
        <div class="stat-card">
            <i class="bi bi-clipboard-check-fill" style="color:#0f3460;"></i>
            <div>
                <div class="stat-num">@Model.Sum(b => b.TotalPoliciesSold)</div>
                <div class="stat-label">Total Policies Sold</div>
            </div>
        </div>
    </div>

    <!-- Brokers Table -->
    @if (Model != null && Model.Any())
    {
        <div class="broker-card">
            <div class="broker-card-header">
                <h5><i class="bi bi-table me-2"></i>All Brokers</h5>
                <input type="text" id="searchBroker" placeholder="Search broker..."
                       class="search-input" maxlength="15" onkeyup="filterBrokers()" />
            </div>
            <div class="table-responsive">
                <table id="brokerTable">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Policies Sold</th>
                            <th>Premium Collected</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var broker in Model)
                        {
                            <tr>
                                <td>@broker.BrokerId</td>
                                <td>
                                    <div class="broker-name-cell">
                                        <div class="broker-avatar">@broker.FullName[0]</div>
                                        @broker.FullName
                                    </div>
                                </td>
                                <td>@broker.Email</td>
                                <td>@broker.PhoneNo</td>
                                <td><span class="policy-count">@broker.TotalPoliciesSold</span></td>
                                <td>₹@broker.TotalPremiumCollected.ToString("N0")</td>
                                <td>
                                    <span class="badge @(broker.IsActive ? "badge-green" : "badge-red")">
                                        @(broker.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <div class="action-btns">
                                        <a asp-action="BrokerPolicies" asp-route-id="@broker.BrokerId"
                                           class="btn-action btn-view" title="View Policies">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <form asp-action="ToggleBrokerStatus" method="post" style="display:inline;">
                                            <input type="hidden" name="brokerId" value="@broker.BrokerId" />
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn-action @(broker.IsActive ? "btn-deactivate" : "btn-activate")"
                                                    title="@(broker.IsActive ? "Deactivate" : "Activate")">
                                                <i class="bi @(broker.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-person-badge"></i>
            <h5>No Brokers Yet</h5>
            <p>Click "Add New Broker" to register your first broker.</p>
        </div>
    }

</div>

<!-- Add Broker Modal -->
<div class="modal fade" id="addBrokerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background:#0f3460; color:#fff;">
                <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Add New Broker</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Admin" asp-action="CreateBroker" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">First Name *</label>
                            <input type="text" name="FirstName" class="form-control" maxlength="20" oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Last Name *</label>
                            <input type="text" name="LastName" class="form-control" maxlength="20" oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email *</label>
                            <input type="email" name="Email" class="form-control" maxlength="50" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone No *</label>
                            <input type="text" name="PhoneNo" class="form-control" maxlength="10" oninput="this.value=this.value.replace(/[^0-9]/g,'')" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Password *</label>
                            <input type="password" name="Password" class="form-control" maxlength="20" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">License Number</label>
                            <input type="text" name="LicenseNumber" class="form-control" maxlength="16"
                                   placeholder="e.g. UP14 20224456667" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn-add">
                        <i class="bi bi-person-plus"></i> Create Broker
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterBrokers() {
            const input = document.getElementById('searchBroker').value.toLowerCase();
            const rows  = document.querySelectorAll('#brokerTable tbody tr');
            rows.forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(input) ? '' : 'none';
            });
        }
            
        setTimeout(function () {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(alert => {
                alert.style.transition = "opacity 0.5s";
                alert.style.opacity = "0";
                setTimeout(() => alert.remove(), 500);
            });
        }, 2000); 

    </script>
}
