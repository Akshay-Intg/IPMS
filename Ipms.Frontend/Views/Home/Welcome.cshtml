<link rel="stylesheet" href="css/Welcome.css"/>
<!DOCTYPE html>
<html lang="en">
<head>
    <title>Insurance Clickable Page</title>
</head>
    <body>
    <!-- ── HERO ── -->
    <section class="hero">
        <div class="hero-left">
            <div class="hero-tag">
                <span> </span> Trusted Insurance Portal
            </div>
            <h1> Protect What <em> Matters Most</em> To Your Family</h1>
            <p> We offer a range of premium insurance packages and innovative policies to protect your life with ease and complete peace of mind.</p>
            <div class="hero-btns">
                <a href="/Auth/Register" class="btn-hero-primary">
                    <i class="bi bi-shield-check"> </i> Get Started Free
                </a>
                <a href="/Auth/Login" class="btn-hero-outline">
                    <i class="bi bi-box-arrow-in-right"> </i> Sign In
                </a>
            </div>
            <div class="hero-stats">
                <div class="stat-item">
                    <div class="stat-num"> 10K + </div>
                    <div class="stat-label"> Customers</div>
                </div>
                <div class="stat-item">
                    <div class="stat-num"> 50 + </div>
                    <div class="stat-label"> Plans</div>
                </div>
                <div class="stat-item">
                    <div class="stat-num"> 99%</div>
                    <div class="stat-label"> Claim Rate</div>
                </div>
            </div>
        </div>

        <div class="hero-right">
            <div class="hero-img-wrap">
                <img src="https://plus.unsplash.com/premium_photo-1681842975607-f3721c013f38?q=80&w=1171&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" alt="Hospital" />
                <div class="float-card">
                    <div class="float-icon"> <i class="bi bi-shield-fill-check"> </i> </div>
                    <div>
                        <div class="float-title"> Coverage Active</div>
                        <div class="float-value"> All Plans Available</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- ── FEATURES ── -->
    <section class="features">
        <div class="section-tag"> Why Choose Us</div>
        <div class="section-title"> Everything You Need, All In One Place</div>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon"> <i class="bi bi-heart-pulse"> </i> </div>
                <h4> Health Insurance</h4>
                <p> Comprehensive health coverage for you and your family with cashless claims at 5000 + hospitals </p>
            </div>
            <div class="feature-card">
                <div class="feature-icon"> <i class="bi bi-house-heart"> </i> </div>
                <h4> Life Insurance</h4>
                <p> Secure your family's future with flexible life insurance plans tailored to your needs </p>
            </div>
            <div class="feature-card">
                <div class="feature-icon"> <i class="bi bi-people"> </i> </div>
                <h4> Group Insurance</h4>
                <p> Affordable group plans for businesses and organizations with seamless enrollment </p>
            </div>
            <div class="feature-card">
                <div class="feature-icon"> <i class="bi bi-life-preserver"> </i></div>
                <h4> Term Insurance</h4>
                <p> Provides a high life cover at affordable premiums for a specific period </p>
            </div>
            <div class="feature-card">
                <div class="feature-icon"> <i class="bi bi-clock-history"> </i> </div>
                <h4> Quick Claims</h4>
                <p> File and track claims online in minutes. Our team processes approvals within 24 hours </p>
            </div>
        </div>
    </section>
    <!-- ── CTA ── -->
    <section class="cta">
        <h2> Ready to Get Protected?</h2>
        <p> Join thousands of families who trust IPMS for their insurance needs.</p>
        <a href="/Auth/Register" class="btn-hero-primary" style="display:inline-flex;">
            <i class="bi bi-arrow-right-circle"> </i> Create Free Account
        </a>
    </section>

</body>
</html>
