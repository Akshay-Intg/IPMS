@model Ipms.Frontend.Models.ClaimsListViewModel
@using Ipms.Frontend.DTOs.Deserialize
@{
    ViewData["Title"] = "Claims List";
}

<link rel="stylesheet" href="~/css/getall.css" />
<link rel="stylesheet" href="~/css/auditlogs.css" />

<div class="customer-list-wrapper">

    <div class="page-header">
        <div>
            <h2><i class="bi bi-journal-text me-2"></i>Claims List</h2>
            <div class="stats-row" style="margin-top:0.5rem; margin-bottom:0;">
                <span class="record-count">
                    Total: @Model.TotalRecords
                </span>
                <span class="record-count" style="background:#fff3cd; color:#856404; border-color:#ffeeba;">
                    ⏳ Pending: @Model.Claims.Count(a => a.ClaimStatus == "Pending")
                </span>
                <span class="record-count" style="background:#e8f5e9; color:#2e7d32; border-color:#a5d6a7;">
                    ✔ Approved: @Model.Claims.Count(a => a.ClaimStatus == "Approved")
                </span>
                <span class="record-count" style="background:#fef0f0; color:#d93025; border-color:#f5c6c6;">
                    ✖ Rejected: @Model.Claims.Count(a => a.ClaimStatus == "Rejected")
                </span>
            </div>
        </div>
        <span class="record-count">
            @Model.TotalRecords Claim@(Model.TotalRecords != 1 ? "s" : "") total
        </span>
    </div>

    @if (TempData["NotFound"] != null)
    {
        <div class="alert alert-danger alert-box rounded-3">@TempData["NotFound"]</div>
    }

    <!-- Search + Filter -->
    <form asp-action="GetClaimsById" method="get" class="search-bar">
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
        <div style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:center;">
            <div class="search-input-wrap">
                <i class="bi bi-search search-icon"></i>
                <input type="text" name="search" value="@Model.Search"
                       placeholder="Search claims..." maxlength="15" />
                @if (!string.IsNullOrEmpty(Model.Search))
                {
                    <a asp-action="GetClaimsById"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-status="@Model.StatusFilter"
                       class="clear-btn">
                        <i class="bi bi-x-lg"></i>
                    </a>
                }
                <button type="submit" class="btn-search">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>

            <select name="status" class="filter-select" onchange="this.form.submit()">
                <option value="">All Status</option>
                <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
                <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
                <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
            </select>
        </div>
    </form>

    <!-- Table -->
    <div class="table-card">
        <div class="table-responsive" style="max-height:65vh; overflow-y:auto;">
            <table class="table table-hover mb-0" style="min-width:800px;">
                <thead>
                    <tr>
                        <th>Claim ID</th>
                        <th>Policy ID</th>
                        <th>Policy Number</th>
                        <th>Claim Status</th>
                        <th>Claim Date</th>
                        <th>Reason</th>
                        <th>Claim Amount</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    @if (Model.Claims.Any())
                    {
                        @foreach (var claim in Model.Claims)
                        {
                            <tr>
                                <td><strong>@claim.ClaimId</strong></td>
                                <td><span class="entity-pill">@claim.PolicyId</span></td>
                                <td>@claim.PolicyNumber</td>
                                <td>
                                    @{
                                        var actionClass = claim.ClaimStatus?.ToLower() switch
                                        {
                                            "pending"  => "action-pending",
                                            "approved" => "action-approved",
                                            "rejected" => "action-rejected",
                                            _          => "action-default"
                                        };
                                    }
                                    <span class="action-badge @actionClass">@claim.ClaimStatus</span>
                                </td>
                                <td>@(claim.ClaimDate.HasValue ? claim.ClaimDate.Value.ToString("dd MMM yyyy, HH:mm") : "-")</td>
                                <td>@claim.Reason</td>
                                <td>₹@claim.ClaimAmount.ToString("N0")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="no-results">
                                <i class="bi bi-journal-x"></i>
                                <span>
                                    @if (!string.IsNullOrEmpty(Model.Search))
                                    {
                                        <span>No claims found for "<strong>@Model.Search</strong>"</span>
                                    }
                                    else
                                    {
                                        <span>No claims found.</span>
                                    }
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages >= 1)
    {
        <div class="pagination-wrapper">
            <div class="pagesize-selector">
                <span>Rows per page:</span>
                @foreach (var size in new[] { 5, 10, 25, 50 })
                {
                    <a asp-action="GetClaimsById"
                       asp-route-page="1"
                       asp-route-search="@Model.Search"
                       asp-route-status="@Model.StatusFilter"
                       asp-route-pageSize="@size"
                       class="@(Model.PageSize == size ? "active-size" : "")">@size</a>
                }
            </div>

            <div class="d-flex align-items-center gap-3">
                <span class="text-muted" style="font-size:0.83rem;">
                    Showing @((Model.CurrentPage - 1) * Model.PageSize + 1)–@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalRecords)) of @Model.TotalRecords
                </span>
                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="GetClaimsById"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-search="@Model.Search"
                               asp-route-status="@Model.StatusFilter"
                               asp-route-pageSize="@Model.PageSize">‹ Prev</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="GetClaimsById"
                                   asp-route-page="@i"
                                   asp-route-search="@Model.Search"
                                   asp-route-status="@Model.StatusFilter"
                                   asp-route-pageSize="@Model.PageSize">@i</a>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="GetClaimsById"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-search="@Model.Search"
                               asp-route-status="@Model.StatusFilter"
                               asp-route-pageSize="@Model.PageSize">Next ›</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }

</div>

@section Scripts {
<script>
    setTimeout(function () {
        document.querySelectorAll('.alert-box').forEach(function (el) {
            el.style.transition = 'opacity 0.5s ease';
            el.style.opacity    = '0';
            setTimeout(() => el.remove(), 500);
        });
    }, 3000);
</script>
}