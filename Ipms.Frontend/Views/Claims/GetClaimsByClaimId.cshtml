@model Ipms.Frontend.DTOs.Deserialize.ClaimsDeserializeDTO

@{
    ViewData["Title"] = "Update Claim Status";
}

<link rel="stylesheet" href="~/css/edit.css" />

<div class="edit-wrapper">
    <div class="edit-card">

        <div class="edit-banner">
            <h6>Insurance Portal</h6>
            <h2><i class="bi bi-pencil-square me-2"></i>Update Claim Status</h2>
        </div>

        <div class="edit-body">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger rounded-3 mb-3">@TempData["Error"]</div>
            }

            <form asp-controller="Claims" asp-action="UpdateClaimStatus" method="post">

                <input type="hidden" asp-for="ClaimId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="section-label">Claim Information</div>
                <div class="row g-3 mb-4">

                    <div class="col-md-6">
                        <label class="form-label">Policy Number</label>
                        <input type="text" class="form-control" asp-for="PolicyNumber" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Claim Date</label>
                        <input type="date" class="form-control"
                               value="@Model.ClaimDate?.ToString("yyyy-MM-dd")" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Claim Amount</label>
                        <input type="text" class="form-control" asp-for="ClaimAmount" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Policy Id</label>
                        <input type="text" class="form-control" asp-for="PolicyId" readonly />
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Reason</label>
                        <textarea class="form-control" rows="3" asp-for="Reason" readonly></textarea>
                    </div>

                </div>

                <div class="section-label">Update Status</div>
                <div class="row g-3 mb-4">

                    <div class="col-md-6">
                        <label class="form-label">Claim Status</label>
                        <select class="form-select" asp-for="ClaimStatus">
                            <option value="">Select Status</option>
                            <option>Pending</option>
                            <option>Approved</option>
                            <option>Rejected</option>
                        </select>
                        <span asp-validation-for="ClaimStatus" class="text-danger small"></span>
                    </div>

                </div>

                <div class="d-flex gap-2 pt-2">
                    <button type="submit" class="btn-save">
                        <i class="bi bi-check-circle"></i> Update Status
                    </button>

                    <a asp-controller="Claims" asp-action="GetClaimsList" class="btn-cancel">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}