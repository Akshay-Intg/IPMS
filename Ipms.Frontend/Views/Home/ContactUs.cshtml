@{
    ViewData["Title"] = "Contact Us";
}

<link rel="stylesheet" href="~/css/Contact.css" />

<div class="edit-wrapper">
    <div class="edit-card">

        <div class="edit-banner">
            <h6>Insurance Portal</h6>
            <h2><i class="bi bi-envelope me-2"></i>Contact Us</h2>
        </div>

        <div class="edit-body">

            <div class="row">

                <div class="col-md-5 contact-info contact-divider">
                    <div class="section-label">Get in Touch</div>

                    <p><strong>IPMS</strong></p>
                    <p><i class="bi bi-telephone"></i> 9354877484</p>
                    <p><i class="bi bi-envelope"></i> ipms.platform@gmail.com</p>

                    <p class="mt-3 text-muted">
                        Our support team is available to assist you with policy queries,
                        claims, and general information.
                    </p>
                </div>

                <div class="col-md-7 ps-4">
                    <div class="section-label">Send Message</div>

                    <form id="contactForm">
                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <input type="text" id="fullName"
                                   class="form-control"
                                   maxlength="30"
                                   placeholder="Enter your name"
                                   oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" id="contactEmail"
                                   class="form-control"
                                   maxlength="50"
                                   placeholder="Enter your email"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea id="message"
                                      class="form-control"
                                      rows="4"
                                      maxlength="300"
                                      placeholder="Write your message"
                                      required></textarea>
                        </div>

                        <button type="submit" class="btn-save">
                            <i class="bi bi-send"></i> Send Message
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

<div id="popupOverlay">
    <div class="popup-box">
        <div class="popup-icon">✅</div>
        <h3>Message Received!</h3>
        <p>
            Thank you for reaching out.<br />
            We’ll get back to you shortly.
        </p>
        <button onclick="closePopup()" class="btn-save mt-2">OK</button>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('contactForm').addEventListener('submit', async function (e) {
            e.preventDefault();

            const name = document.getElementById('fullName').value.trim();
            const email = document.getElementById('contactEmail').value.trim();
            const message = document.getElementById('message').value.trim();

            if (!name || !email || !message) {
                alert('Please fill all fields before sending.');
                return;
            }

            const btn = document.querySelector('button[type="submit"]');
            btn.disabled = true;
            btn.textContent = 'Sending...';

            try {
                const response = await fetch('https://localhost:7008/api/Auth/send-contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        fullName: name,
                        email: email,
                        message: message
                    })
                });

                const data = await response.json();

                if (response.ok) {
                    document.getElementById('popupOverlay').style.display = 'flex';
                    document.getElementById('contactForm').reset();
                } else {
                    alert(data.message || 'Something went wrong.');
                }
            }
            catch (err) {
                alert('Network error. Please try again.');
            }

            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-send"></i> Send Message';
        });

        function closePopup() {
            document.getElementById('popupOverlay').style.display = 'none';
        }

        document.getElementById('popupOverlay').addEventListener('click', function (e) {
            if (e.target === this) closePopup();
        });
    </script>
}