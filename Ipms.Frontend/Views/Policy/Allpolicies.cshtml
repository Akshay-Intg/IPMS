@model Ipms.Frontend.Models.PolicyListPagedViewModel
@{
    ViewData["Title"] = "All Policies";
}

<link rel="stylesheet" href="~/css/getall.css" />
<style>
    #tableBody td:first-child {
        white-space: nowrap !important;
    }
</style>

<div class="customer-list-wrapper">

    <div class="page-header">
        <div>
            <h2><i class="bi bi-file-earmark-text me-2"></i>All Policies</h2>
            <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-top:0.5rem;">
                <span class="record-count" style="background:#e6f9f0; color:#1a9e5c; border-color:#b6ecd4;">
                    ✔ Active: @Model.Policies.Count(p => p.PolicyStatus == "Active")
                </span>
                <span class="record-count" style="background:#fff8e1; color:#f57f17; border-color:#ffe082;">
                    ⏳ Pending: @Model.Policies.Count(p => p.PolicyStatus == "Pending")
                </span>
                <span class="record-count">
                    ₹ Total Premium: ₹@Model.Policies.Sum(p => p.PremiumAmount).ToString("N0")
                </span>
            </div>
        </div>
        <span class="record-count">
            @Model.TotalRecords polic@(Model.TotalRecords != 1 ? "ies" : "y") total
        </span>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3 mb-3">@TempData["Error"]</div>
    }

    <form asp-action="AllPolicies" method="get" class="search-bar">
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
        <div style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:center; margin-bottom:1.25rem;">
            <div class="search-input-wrap">
                <i class="bi bi-search search-icon"></i>
                <input type="text" name="search" value="@Model.Search"
                       placeholder="Search by name, policy no, type..." />
                @if (!string.IsNullOrEmpty(Model.Search))
                {
                    <a asp-action="AllPolicies"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-status="@Model.StatusFilter"
                       class="clear-btn">
                        <i class="bi bi-x-lg"></i>
                    </a>
                }
                <button type="submit" class="btn-search">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>

            <select name="status" class="filter-select" onchange="this.form.submit()">
                <option value="">All Status</option>
                <option value="Active" selected="@(Model.StatusFilter == "Active")">Active</option>
                <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
                <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
            </select>
        </div>
    </form>

    <div class="table-card">
        <div class="table-responsive" style="max-height:60vh; overflow-y:auto;">
            <table class="table table-hover mb-0" style="min-width:1100px;">
                <thead>
                    <tr>
                        <th>Policy No.</th>
                        <th>Customer</th>
                        <th>Type</th>
                        <th>Scheme</th>
                        <th>Sum Assured</th>
                        <th>Premium / yr</th>
                        <th>Term</th>
                        <th>Start Date</th>
                        <th>Maturity Date</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    @if (Model.Policies.Any())
                    {
                        @foreach (var p in Model.Policies)
                        {
                            <tr>
                                <td><strong>@p.PolicyNumber</strong></td>
                                <td>@(p.CustomerName ?? "-")</td>
                                <td>@(p.InsuranceType ?? "-")</td>
                                <td>@(p.SchemeName ?? "-")</td>
                                <td>₹@p.SumAssured.ToString("N0")</td>
                                <td>₹@p.PremiumAmount.ToString("N0")</td>
                                <td>@(p.PolicyTerm.HasValue? p.PolicyTerm + " yr" : "-")</td>
                                <td>@(p.PolicyDate.HasValue? p.PolicyDate.Value.ToString("dd MMM yyyy") : "-")</td>
                                <td>@(p.MaturityDate.HasValue? p.MaturityDate.Value.ToString("dd MMM yyyy") : "-")</td>
                                <td style="white-space:nowrap; vertical-align:middle;">
                                    @if (p.PolicyStatus == "Active")
                                    {
                                        <span class="badge-active">● Active</span>
                                    }
                                    else if (p.PolicyStatus == "Rejected")
                                    {
                                        <span class="badge-inactive">● Rejected</span>
                                    }
                                    else
                                    {
                                        <span class="badge-orange">● @p.PolicyStatus</span>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="Policy"
                                       asp-action="Review"
                                       asp-route-id="@p.PolicyId"
                                       class="btn-edit">
                                        <i class="bi bi-pencil-square"></i> Review
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11" class="no-results">
                                <i class="bi bi-file-earmark-x"></i>
                                <span>
                                    @if (!string.IsNullOrEmpty(Model.Search))
                                    {
                                        <span>No policies found for "<strong>@Model.Search</strong>"</span>
                                    }
                                    else
                                    {
                                        <span>No policies found.</span>
                                    }
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages >= 1)
    {
        <div class="pagination-wrapper">
            <div class="pagesize-selector">
                <span>Rows per page:</span>
                @foreach (var size in new[] { 5, 10, 25, 50 })
                {
                    <a asp-action="AllPolicies"
                       asp-route-page="1"
                       asp-route-search="@Model.Search"
                       asp-route-status="@Model.StatusFilter"
                       asp-route-pageSize="@size"
                       class="@(Model.PageSize == size ? "active-size" : "")">@size</a>
                }
            </div>

            <div class="d-flex align-items-center gap-3">
                <span class="text-muted" style="font-size:0.83rem;">
                    Showing @((Model.CurrentPage - 1) * Model.PageSize + 1)–@(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalRecords)) of @Model.TotalRecords
                </span>
                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="AllPolicies"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-search="@Model.Search"
                               asp-route-status="@Model.StatusFilter"
                               asp-route-pageSize="@Model.PageSize">‹ Prev</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="AllPolicies"
                                   asp-route-page="@i"
                                   asp-route-search="@Model.Search"
                                   asp-route-status="@Model.StatusFilter"
                                   asp-route-pageSize="@Model.PageSize">@i</a>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="AllPolicies"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-search="@Model.Search"
                               asp-route-status="@Model.StatusFilter"
                               asp-route-pageSize="@Model.PageSize">Next ›</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    }

</div>