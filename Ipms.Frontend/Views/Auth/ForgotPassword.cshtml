@{
    ViewData["Title"] = "Forgot Password";
}

<link rel="stylesheet" href="~/css/ForgotPassword.css" />

<style>
    .step {
        display: none;
    }

        .step.active {
            display: block;
        }

    .otp-inputs {
        display: flex;
        gap: 8px;
        justify-content: center;
        margin: 1rem 0;
    }

    .otp-box {
        width: 46px;
        height: 52px;
        text-align: center;
        font-size: 1.3rem;
        font-weight: 700;
        border: 1px solid #ccd9e0;
        border-radius: 6px;
        outline: none;
        background: #f5fafd;
        color: #2c3e50;
        font-family: 'Poppins', sans-serif;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .otp-box:focus {
            border-color: #AACDDC;
            box-shadow: 0 0 0 3px rgba(170,205,220,0.25);
            background: #fff;
        }

    .email-display {
        background: #f5fafd;
        border: 1px solid #ccd9e0;
        border-radius: 6px;
        padding: 8px 14px;
        font-size: 0.85rem;
        color: #2c3e50;
        font-weight: 600;
        text-align: center;
        margin-bottom: 1rem;
    }

    .resend-link {
        text-align: center;
        font-size: 13px;
        color: #777;
        margin-top: 14px;
    }

        .resend-link a {
            color: #2c3e50;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
        }

            .resend-link a:hover {
                text-decoration: underline;
            }
</style>

@Html.AntiForgeryToken()

<div class="login-wrapper">
    <div class="login-card">

        <div class="login-header">
            <h1>IPMS</h1>
            <p>Insurance Policy Management System</p>
        </div>

        <div id="alertBox" style="display:none;"></div>

        <div class="step active" id="step1">

            <h2 class="login-title">Forgot Password</h2>
            <p class="login-sub">Enter your email to receive an OTP</p>

            <div class="info-box">
                ℹ️ A 6-digit OTP will be sent to your registered email address.
            </div>

            <div class="form-group">
                <label>Email Address</label>
                <input type="email" class="form-input" id="emailInput" placeholder="Enter your registered email" maxlength="50" required/>
            </div>

            <button class="login-btn" id="sendOtpBtn" onclick="sendOTP()">
                <span id="sendBtnText">Send OTP</span>
                <span id="sendSpinner" class="spinner-border spinner-border-sm d-none"></span>
            </button>

            <p class="register-link">
                Remember your password? <a href="/Auth/Login">Login here</a>
            </p>

        </div>

        <div class="step" id="step2">

            <h2 class="login-title">Verify OTP</h2>
            <p class="login-sub">Enter the 6-digit OTP sent to</p>

            <div class="email-display" id="emailDisplay"></div>

            <div class="info-box">
                ⏱️ OTP expires in <strong>10 minutes</strong>. Check spam if not received.
            </div>

            <label style="font-size:13px; font-weight:500; color:#2c3e50; display:block; margin-bottom:6px;">
                Enter OTP
            </label>
            <div class="otp-inputs">
                <input type="text" class="otp-box" maxlength="1" id="otp1"
                       oninput="otpMove(this, null,   'otp2')"
                       onkeydown="otpBack(event, this, null,   'otp2')" />
                <input type="text" class="otp-box" maxlength="1" id="otp2"
                       oninput="otpMove(this, 'otp1', 'otp3')"
                       onkeydown="otpBack(event, this, 'otp1', 'otp3')" />
                <input type="text" class="otp-box" maxlength="1" id="otp3"
                       oninput="otpMove(this, 'otp2', 'otp4')"
                       onkeydown="otpBack(event, this, 'otp2', 'otp4')" />
                <input type="text" class="otp-box" maxlength="1" id="otp4"
                       oninput="otpMove(this, 'otp3', 'otp5')"
                       onkeydown="otpBack(event, this, 'otp3', 'otp5')" />
                <input type="text" class="otp-box" maxlength="1" id="otp5"
                       oninput="otpMove(this, 'otp4', 'otp6')"
                       onkeydown="otpBack(event, this, 'otp4', 'otp6')" />
                <input type="text" class="otp-box" maxlength="1" id="otp6"
                       oninput="otpMove(this, 'otp5', null)"
                       onkeydown="otpBack(event, this, 'otp5', null)" />
            </div>

            <div class="form-group mt-3">
                <label>New Password</label>
                <input type="password" class="form-input" id="newPassword"
                       placeholder="Enter new password (min 6 characters)" />
            </div>

            <div class="form-group">
                <label>Confirm Password</label>
                <input type="password" class="form-input" id="confirmPassword"
                       placeholder="Confirm new password" />
            </div>

            <button class="login-btn" id="resetBtn" onclick="resetPassword()">
                <span id="resetBtnText">Reset Password</span>
                <span id="resetSpinner" class="spinner-border spinner-border-sm d-none"></span>
            </button>

            <div class="resend-link">
                Didn't receive OTP? <a onclick="resendOTP()">Resend OTP</a>
                &nbsp;|&nbsp;
                <a onclick="goBack()">Change Email</a>
            </div>

        </div>

    </div>
</div>

@section Scripts {
    <script>
        let userEmail = '';

        function otpMove(current, prevId, nextId) {
            current.value = current.value.replace(/[^0-9]/g, '');
            if (current.value && nextId)
                document.getElementById(nextId).focus();
        }

        function otpBack(e, current, prevId, nextId) {
            if (e.key === 'Backspace' && !current.value && prevId)
                document.getElementById(prevId).focus();
        }

        function getOTP() {
            return ['otp1','otp2','otp3','otp4','otp5','otp6']
                .map(id => document.getElementById(id).value).join('');
        }

        function clearOTP() {
            ['otp1','otp2','otp3','otp4','otp5','otp6']
                .forEach(id => document.getElementById(id).value = '');
        }

        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        }

        async function sendOTP() {
            const email = document.getElementById('emailInput').value.trim();
            if (!email) { showAlert('Please enter your email address.', 'error'); return; }

            setLoading('send', true);
            hideAlert();

            try {
                const response = await fetch('/Auth/ForgotPassword', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
                    body:    JSON.stringify({ email })
                });
                const data = await response.json();

                if (response.ok) {
                    userEmail = email;
                    document.getElementById('emailDisplay').textContent = email;
                    showStep(2);
                    showAlert('✔ OTP sent! Check your email.', 'success');
                    document.getElementById('otp1').focus();
                } else {
                    showAlert('⚠️ ' + (data.message || 'Something went wrong.'), 'error');
                }
            } catch (err) {
                showAlert('Network error: ' + err.message, 'error');
            } finally {
                setLoading('send', false);
            }
        }

        async function resetPassword() {
            const otp         = getOTP();
            const newPassword = document.getElementById('newPassword').value;
            const confirmPass = document.getElementById('confirmPassword').value;

            if (otp.length < 6)              { showAlert('Please enter the complete 6-digit OTP.', 'error'); return; }
            if (!newPassword)                { showAlert('Please enter a new password.', 'error'); return; }
            if (newPassword.length < 6)      { showAlert('Password must be at least 6 characters.', 'error'); return; }
            if (newPassword !== confirmPass) { showAlert('Passwords do not match.', 'error'); return; }

            setLoading('reset', true);
            hideAlert();

            try {
                const response = await fetch('/Auth/VerifyOtp', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
                    body:    JSON.stringify({ email: userEmail, otp, newPassword })
                });
                const data = await response.json();

                if (response.ok) {
                    showAlert('✔ Password reset successfully! Redirecting...', 'success');
                    setTimeout(() => window.location.href = '/Auth/Login', 2000);
                } else {
                    showAlert('⚠️ ' + (data.message || 'Invalid OTP.'), 'error');
                    clearOTP();
                    document.getElementById('otp1').focus();
                }
            } catch (err) {
                showAlert('Network error: ' + err.message, 'error');
            } finally {
                setLoading('reset', false);
            }
        }

        async function resendOTP() {
            clearOTP();
            hideAlert();
            setLoading('send', true);

            try {
                const response = await fetch('/Auth/ForgotPassword', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
                    body:    JSON.stringify({ email: userEmail })
                });
                const data = await response.json();
                showAlert(response.ok
                    ? '✔ New OTP sent to ' + userEmail
                    : '⚠️ ' + (data.message || 'Failed.'),
                    response.ok ? 'success' : 'error');
            } catch (err) {
                showAlert('Network error.', 'error');
            } finally {
                setLoading('send', false);
            }
        }

        function goBack() { showStep(1); hideAlert(); clearOTP(); }

        function showStep(n) {
            document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
            document.getElementById('step' + n).classList.add('active');
        }

        function setLoading(btn, val) {
            if (btn === 'send') {
                document.getElementById('sendOtpBtn').disabled     = val;
                document.getElementById('sendBtnText').textContent = val ? 'Sending...' : 'Send OTP';
                document.getElementById('sendSpinner').classList.toggle('d-none', !val);
            } else {
                document.getElementById('resetBtn').disabled        = val;
                document.getElementById('resetBtnText').textContent = val ? 'Resetting...' : 'Reset Password';
                document.getElementById('resetSpinner').classList.toggle('d-none', !val);
            }
        }

        function showAlert(msg, type) {
            const box     = document.getElementById('alertBox');
            box.className = type === 'success' ? 'alert-success' : 'alert-error';
            box.textContent  = msg;
            box.style.display = 'block';
        }

        function hideAlert() {
            document.getElementById('alertBox').style.display = 'none';
        }
    </script>
}
